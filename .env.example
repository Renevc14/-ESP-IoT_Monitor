# ─── Supabase Database ───────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format with ?sslmode=require appended
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# ─── Frontend Build Args ──────────────────────────────────────────────────────
VITE_GATEWAY_URL=http://localhost:8000
VITE_ANALYTICS_URL=http://localhost:8004
VITE_WS_URL=ws://localhost:8003

# ─── Simulator ───────────────────────────────────────────────────────────────
SIMULATOR_EMAIL=operator@iot.local
SIMULATOR_PASSWORD=Operator1234!
SIM_DEVICES=3
SIM_READINGS=10
