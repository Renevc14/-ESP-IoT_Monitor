# ─── Base de datos ────────────────────────────────────────────────────────────
# Por defecto se usa el contenedor local postgres-timescale (TimescaleDB).
# Estas credenciales inicializan ese contenedor.
POSTGRES_USER=iot
POSTGRES_PASSWORD=iot
POSTGRES_DB=iot
# DATABASE_URL apunta al contenedor local por defecto. Para usar Timescale Cloud,
# descomenta la línea de abajo con tu cadena (driver asyncpg, ?ssl=require).
DATABASE_URL=postgresql+asyncpg://iot:iot@postgres-timescale:5432/iot
# DATABASE_URL=postgresql+asyncpg://tsdbadmin:[YOUR-PASSWORD]@[YOUR-HOST].tsdb.cloud.timescale.com:[PORT]/tsdb?ssl=require

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ─── Email de alertas (SMTP) ─────────────────────────────────────────────────
# Por defecto usa el contenedor MailHog (bandeja de demo en http://localhost:8025).
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=alerts@iot.local
# Destinatarios por defecto (coma-separados) cuando una regla no define los suyos.
ALERT_EMAILS=ops@iot.local

# ─── Frontend Build Args ──────────────────────────────────────────────────────
VITE_GATEWAY_URL=http://localhost:8000
VITE_ANALYTICS_URL=http://localhost:8004
VITE_WS_URL=ws://localhost:8003

# ─── Simulator ───────────────────────────────────────────────────────────────
# MODE: continuous (default) | demo
# INTERVAL: seconds between cycles in continuous mode (default: 60)
OPERATOR_EMAIL=operator@iot.local
OPERATOR_PASSWORD=Operator1234!
MODE=continuous
INTERVAL=60
