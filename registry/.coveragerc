# Cobertura sobre la lógica de autenticación por claims; routers/DB/modelos por integración.
[run]
omit =
    app/main.py
    app/config.py
    app/observability.py
    app/db/*
    app/models/*
    app/schemas/*
    app/routers/*
    app/services/*
    app/__init__.py

[report]
show_missing = True
fail_under = 80
